+            self._pair_forward_gate.close()
+            self._pair_forward_gate = None
         if self.rpc_broadcast_mq is not None:
             self.rpc_broadcast_mq.shutdown()
         if self.worker_response_mq is not None:
@@ -935,14 +962,30 @@ class WorkerProc:
             method, args, kwargs, output_rank = self.rpc_broadcast_mq.dequeue(
                 indefinite=True
             )
+            forward_round = None
             try:
                 if isinstance(method, str):
                     func = getattr(self.worker, method)
                 elif isinstance(method, bytes):
                     func = partial(cloudpickle.loads(method), self.worker)
 
+                is_nonempty_forward = (
+                    method == "execute_model"
+                    and args
+                    and args[0].total_num_scheduled_tokens > 0
+                )
+                if (
+                    is_nonempty_forward
+                    and self._pair_forward_gate is not None
+                    and os.environ.get("VLLM_PAIR_SCHED_DEBUG_BYPASS") != "1"
+                ):
+                    forward_round = self._pair_forward_gate.enter_forward()
                 output = func(*args, **kwargs)
+                if forward_round is not None:
