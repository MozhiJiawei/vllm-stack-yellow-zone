+        enabled = self.model_executor.collective_rpc(
+            "det_sched_enter", args=(runnable,)
+        )
+        if len(enabled) != self._det_sched_tp:
+            raise RuntimeError(
+                f"deterministic scheduling expected {self._det_sched_tp} TP workers, "
+                f"got {len(enabled)}"
+            )
+        if any(enabled) and not all(enabled):
+            raise RuntimeError("mixed vCANN deterministic runtime detected")
+        if not any(enabled):
+            self._det_sched_enabled = False
+            return False
+        if getattr(self, "batch_queue", None) is not None:
+            raise RuntimeError(
+                "deterministic v1 does not support PP or concurrent batch queues"
+            )
+        if self._det_sched_tp not in (1, 2, 4, 8):
+            raise RuntimeError("deterministic elastic scheduling supports TP1/2/4/8")
+
+        self._det_sched_enabled = True
+        return True
