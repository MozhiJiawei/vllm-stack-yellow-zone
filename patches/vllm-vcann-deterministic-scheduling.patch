index ae67491..deb44d6 100644
--- a/tests/v1/engine/test_engine_core.py
+++ b/tests/v1/engine/test_engine_core.py
@@ -601,3 +601,80 @@ def test_encoder_instance_zero_kv_cache(
         assert not engine_core.scheduler.ec_connector.is_producer, (
             "Consumer instance EC connector should be consumer"
         )
+
+
+@pytest.mark.parametrize("tp", [1, 2, 4, 8])
+def test_deterministic_enter_has_one_reply_per_tp_worker(tp):
+    calls = []
+    core = object.__new__(EngineCore)
+    core._det_sched_enabled = None
+    core._det_sched_tp = tp
+    core.model_executor = type(
+        "Executor",
+        (),
+        {
+            "collective_rpc": lambda _, method, args: (
+                calls.append((method, args)) or [True] * tp
+            )
+        },
+    )()
+
+    assert core._det_sched_enter(True)
+    assert calls == [("det_sched_enter", (True,))]
+
+
+def test_deterministic_enter_skips_initial_idle_once():
+    calls = []
+    core = object.__new__(EngineCore)
+    core._det_sched_enabled = None
+    core._det_sched_initial_idle = True
+    core._det_sched_tp = 1
+    core.model_executor = type(
+        "Executor",
+        (),
+        {"collective_rpc": lambda *_args, **_kwargs: calls.append(1) or [True]},
+    )()
+
+    assert not core._det_sched_enter(False)
+    assert calls == []
+    assert not core._det_sched_initial_idle
+    assert core._det_sched_enter(False)
+    assert calls == [1]
+
+
+def test_deterministic_enter_disables_when_abi_is_unavailable():
+    core = object.__new__(EngineCore)
+    core._det_sched_enabled = None
+    core._det_sched_tp = 2
+    core.model_executor = type(
+        "Executor", (), {"collective_rpc": lambda *_args, **_kwargs: [False, False]}
+    )()
+
+    assert not core._det_sched_enter(False)
+    assert core._det_sched_enabled is False
+
+
+def test_deterministic_enter_rejects_batch_queue():
+    core = object.__new__(EngineCore)
+    core._det_sched_enabled = None
+    core._det_sched_tp = 1
+    core.batch_queue = object()
+    core.model_executor = type(
+        "Executor", (), {"collective_rpc": lambda *_args, **_kwargs: [True]}
+    )()
+
+    with pytest.raises(RuntimeError, match="batch queue"):
+        core._det_sched_enter(True)
+
+
+@pytest.mark.parametrize("replies", [[True], [True, False]])
+def test_deterministic_enter_rejects_inconsistent_tp_replies(replies):
+    core = object.__new__(EngineCore)
+    core._det_sched_enabled = None
+    core._det_sched_tp = 2
+    core.model_executor = type(
+        "Executor", (), {"collective_rpc": lambda *_args, **_kwargs: replies}
+    )()
+
+    with pytest.raises(RuntimeError):
+        core._det_sched_enter(True)
