+import ctypes
+from collections.abc import Iterator, Mapping
+from contextlib import contextmanager
+from typing import Any
+
+from vllm.logger import logger
+
+_VCANN_SUCCESS = 0
+
+
+class _VcannPrefillApi:
+    def __init__(self, library: Any) -> None:
+        self.begin = library.rtBeginPrefill
+        self.begin.argtypes = []
+        self.begin.restype = ctypes.c_int
+        self.end = library.rtEndPrefill
+        self.end.argtypes = []
+        self.end.restype = ctypes.c_int
+
+
+def _load_vcann_prefill_api() -> _VcannPrefillApi | None:
+    try:
+        return _VcannPrefillApi(ctypes.CDLL(None))
+    except (AttributeError, OSError, TypeError):
+        # The symbols exist only when libvruntime.so is preloaded. Keep native
+        # vLLM-Ascend deployments unchanged when vCANN is not installed.
+        return None
+
+
+_VCANN_PREFILL_API = _load_vcann_prefill_api()
+
+
+def batch_contains_prefill(attn_metadata: Any) -> bool:
+    """Return whether any attention group in this model step has prefill work."""
+    groups = attn_metadata if isinstance(attn_metadata, list) else [attn_metadata]
+    visited: set[int] = set()
+    for group in groups:
+        if not isinstance(group, Mapping):
+            continue
+        for metadata in group.values():
+            metadata_id = id(metadata)
+            if metadata_id in visited:
+                continue
+            visited.add(metadata_id)
+            num_prefills = getattr(metadata, "num_prefills", 0)
+            if num_prefills is not None and num_prefills > 0:
+                return True
+    return False
+
+
+@contextmanager
+def vcann_prefill_guard(enabled: bool) -> Iterator[None]:
+    """Keep the current vNPU owner for the complete model-forward prefill."""
+    api = _VCANN_PREFILL_API
+    if not enabled or api is None:
+        yield
+        return
+
+    result = api.begin()
+    if result != _VCANN_SUCCESS:
+        raise RuntimeError(f"rtBeginPrefill failed with error code {result}")
+
+    body_failed = False
+    try:
+        yield
+    except BaseException:
+        body_failed = True
+        raise
+    finally:
+        result = api.end()
+        if result != _VCANN_SUCCESS:
+            message = f"rtEndPrefill failed with error code {result}"
+            if body_failed:
+                logger.error(message)
+            else:
+                raise RuntimeError(message)
