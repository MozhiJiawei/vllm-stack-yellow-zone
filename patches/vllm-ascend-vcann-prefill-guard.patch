diff --git a/tests/ut/test_vcann.py b/tests/ut/test_vcann.py
new file mode 100644
index 00000000..174b8501
--- /dev/null
+++ b/tests/ut/test_vcann.py
@@ -0,0 +1,75 @@
+from types import SimpleNamespace
+
+import pytest
+from vllm_ascend import vcann
+
+
+class FakePrefillApi:
+    def __init__(self, begin_result=0, end_result=0):
+        self.begin_result = begin_result
+        self.end_result = end_result
+        self.calls = []
+
+    def begin(self):
+        self.calls.append("begin")
+        return self.begin_result
+
+    def end(self):
+        self.calls.append("end")
+        return self.end_result
+
+
+def test_batch_contains_prefill_for_dict_and_ubatches():
+    decode = SimpleNamespace(num_prefills=0)
+    prefill = SimpleNamespace(num_prefills=1)
+
+    assert not vcann.batch_contains_prefill({"layer.0": decode})
+    assert vcann.batch_contains_prefill({"layer.0": prefill})
+    assert vcann.batch_contains_prefill([{"layer.0": decode}, {"layer.0": prefill}])
+
+
+def test_prefill_guard_is_noop_without_vcann(monkeypatch):
+    monkeypatch.setattr(vcann, "_VCANN_PREFILL_API", None)
+
+    with vcann.vcann_prefill_guard(True):
+        pass
+
+
+def test_prefill_guard_pairs_begin_and_end(monkeypatch):
+    api = FakePrefillApi()
+    monkeypatch.setattr(vcann, "_VCANN_PREFILL_API", api)
+
+    with vcann.vcann_prefill_guard(True):
+        assert api.calls == ["begin"]
+
+    assert api.calls == ["begin", "end"]
+
+
+def test_prefill_guard_ends_after_model_error(monkeypatch):
+    api = FakePrefillApi()
+    monkeypatch.setattr(vcann, "_VCANN_PREFILL_API", api)
+
+    with pytest.raises(ValueError, match="model failed"), vcann.vcann_prefill_guard(True):
+        raise ValueError("model failed")
+
+    assert api.calls == ["begin", "end"]
+
+
+def test_prefill_guard_does_not_end_after_failed_begin(monkeypatch):
+    api = FakePrefillApi(begin_result=7)
+    monkeypatch.setattr(vcann, "_VCANN_PREFILL_API", api)
+
+    with pytest.raises(RuntimeError, match="rtBeginPrefill failed"), vcann.vcann_prefill_guard(True):
+        pass
+
+    assert api.calls == ["begin"]
+
+
+def test_prefill_guard_reports_failed_end(monkeypatch):
+    api = FakePrefillApi(end_result=9)
+    monkeypatch.setattr(vcann, "_VCANN_PREFILL_API", api)
+
+    with pytest.raises(RuntimeError, match="rtEndPrefill failed"), vcann.vcann_prefill_guard(True):
+        pass
+
+    assert api.calls == ["begin", "end"]
