@@ -0,0 +1,130 @@
+import ctypes
+from types import SimpleNamespace
+
+import pytest
+
+from vllm_ascend import vcann
+from vllm_ascend.worker.worker import NPUWorker
+
+
+class FakeApi:
+    def __init__(self):
+        self.enabled = True
+        self.calls = []
+        self.enter_result = 0
+        self.end_result = 0
+
+    def enter(self, ready, enabled):
+        self.calls.append(("enter", ready))
+        ctypes.cast(enabled, ctypes.POINTER(ctypes.c_bool))[0] = self.enabled
+        return self.enter_result
+
+    def end(self):
+        self.calls.append(("end",))
+        return self.end_result
+
+
+def test_missing_abi_is_noop(monkeypatch):
+    monkeypatch.setattr(vcann, "_API", None)
+    assert not vcann.enter(True)
+    vcann.end()
+
+
+def test_non_elastic_enter_is_noop(monkeypatch):
+    api = FakeApi()
+    api.enabled = False
+    monkeypatch.setattr(vcann, "_API", api)
+
+    assert not vcann.enter(True)
+    assert [call[0] for call in api.calls] == ["enter"]
+
+
+def test_active_step_calls_two_abi(monkeypatch):
+    api = FakeApi()
+    monkeypatch.setattr(vcann, "_API", api)
+
+    assert vcann.enter(True)
+    vcann.end()
+    assert [call[0] for call in api.calls] == ["enter", "end"]
+
+
+def test_enter_failure_does_not_end(monkeypatch):
+    api = FakeApi()
+    api.enter_result = 7
+    monkeypatch.setattr(vcann, "_API", api)
+
+    with pytest.raises(RuntimeError, match="rtDetSchedEnter"):
+        vcann.enter(True)
+    assert [call[0] for call in api.calls] == ["enter"]
+
+
+def test_failed_body_cleanup_logs_end_failure(monkeypatch):
+    api = FakeApi()
+    api.end_result = 9
+    monkeypatch.setattr(vcann, "_API", api)
+
+    vcann.end(body_failed=True)
+    assert api.calls == [("end",)]
+
+
+def test_worker_ends_immediate_output_once(monkeypatch):
+    calls = []
+    output = object()
+    worker = object.__new__(NPUWorker)
+    worker._vcann_active = True
+    worker._execute_model = lambda _scheduler_output: output
+    monkeypatch.setattr(vcann, "end", lambda failed=False: calls.append(failed))
+
+    assert NPUWorker.execute_model(worker, object()) is output
+    assert calls == [False]
+    assert not worker._vcann_active
+
+
+def test_worker_keeps_guard_through_delayed_sampling(monkeypatch):
+    calls = []
+    output = object()
+    worker = object.__new__(NPUWorker)
+    worker._vcann_active = True
+    worker._execute_model = lambda _scheduler_output: None
+    worker.model_runner = SimpleNamespace(sample_tokens=lambda _grammar: output)
+    monkeypatch.setattr(vcann, "end", lambda failed=False: calls.append(failed))
+
+    assert NPUWorker.execute_model(worker, object()) is None
+    assert calls == []
+    assert NPUWorker.sample_tokens(worker, object()) is output
+    assert calls == [False]
+    assert not worker._vcann_active
+
+
+def test_worker_ends_failed_execution_once(monkeypatch):
+    calls = []
+
+    def failed_execute(_scheduler_output):
+        raise RuntimeError("model failed")
+
+    worker = object.__new__(NPUWorker)
+    worker._vcann_active = True
+    worker._execute_model = failed_execute
+    monkeypatch.setattr(vcann, "end", lambda failed=False: calls.append(failed))
+
+    with pytest.raises(RuntimeError, match="model failed"):
+        NPUWorker.execute_model(worker, object())
+    assert calls == [True]
+    assert not worker._vcann_active
+
+
+def test_worker_ends_failed_sampling_once(monkeypatch):
+    calls = []
+
+    def failed_sample(_grammar):
+        raise RuntimeError("sample failed")
+
+    worker = object.__new__(NPUWorker)
+    worker._vcann_active = True
+    worker.model_runner = SimpleNamespace(sample_tokens=failed_sample)
+    monkeypatch.setattr(vcann, "end", lambda failed=False: calls.append(failed))
+
+    with pytest.raises(RuntimeError, match="sample failed"):
+        NPUWorker.sample_tokens(worker, object())
+    assert calls == [True]
+    assert not worker._vcann_active
