@@ -0,0 +1,53 @@
+# Copyright (c) 2026 Huawei Technologies Co., Ltd. All Rights Reserved.
+# Licensed under the Apache License, Version 2.0 (the "License");
+
+import ctypes
+from typing import Any
+
+from vllm.logger import logger
+
+_SUCCESS = 0
+
+
+class _DetSchedApi:
+    def __init__(self, library: Any) -> None:
+        self.enter = library.rtDetSchedEnter
+        self.enter.argtypes = [ctypes.c_bool, ctypes.POINTER(ctypes.c_bool)]
+        self.enter.restype = ctypes.c_int
+        self.end = library.rtDetSchedEnd
+        self.end.argtypes = []
+        self.end.restype = ctypes.c_int
+
+
+def _load_api() -> _DetSchedApi | None:
+    try:
+        return _DetSchedApi(ctypes.CDLL(None))
+    except (AttributeError, OSError, TypeError):
+        return None
+
+
+_API = _load_api()
+
+
+def enter(ready: bool) -> bool:
+    """Enter the current READY decision; unavailable/non-elastic is a no-op."""
+    if _API is None:
+        return False
+    enabled = ctypes.c_bool()
+    rc = _API.enter(ready, ctypes.byref(enabled))
+    if rc != _SUCCESS:
+        raise RuntimeError(f"rtDetSchedEnter failed with error code {rc}")
+    return enabled.value
+
+
+def end(body_failed: bool = False) -> None:
+    if _API is None:
+        return
+    rc = _API.end()
+    if rc == _SUCCESS:
+        return
+    message = f"rtDetSchedEnd failed with error code {rc}"
+    if body_failed:
+        logger.error(message)
+    else:
+        raise RuntimeError(message)
